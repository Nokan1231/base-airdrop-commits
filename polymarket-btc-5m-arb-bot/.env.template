# Copy this file to .env and fill in your values
# Never commit your actual .env file

# Polymarket CLOB API credentials
# Get these from https://clob.polymarket.com
POLY_PRIVATE_KEY=your_ethereum_private_key_hex_no_0x_prefix
POLY_API_KEY=your_clob_api_key
POLY_API_SECRET=your_clob_api_secret
POLY_API_PASSPHRASE=your_clob_api_passphrase

# Optional overrides (defaults in config.yaml)
POSITION_SIZE_USDC=10
MAX_DAILY_LOSS_USDC=50
MAX_OPEN_POSITIONS=3
